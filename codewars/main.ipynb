                              "source": [
                                        "#   high_and_low(\"1 2 3 4 5\") # return \"5 1\"\n",
                                        "\n",
                                        "def high_and_low(numbers):\n",
                                        "    nums = [int(i) for i in numbers.split()]\n",
                                        "    return f\"{max(nums)} {min(nums)}\""
                              ]
                    },
